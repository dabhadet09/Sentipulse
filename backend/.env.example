# Application
APP_NAME=SentiPulse
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MongoDB — choose ONE option below

# Option A: Local MongoDB
MONGODB_URL=mongodb://localhost:27017/User

# Option B: MongoDB Atlas (cloud — recommended for project demo)
# MONGODB_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Tip: URL-encode special chars in password (@ → %40, # → %23)

DATABASE_NAME=sentipulse

# Admin (created on first startup if not exists)
ADMIN_EMAIL=admin@sentipulse.com
ADMIN_PASSWORD=Admin@123456

# ML Models (Hugging Face model IDs)
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
MULTILINGUAL_MODEL=google/muril-base-cased
ROBERTA_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# Platform API Keys

# YouTube Data API v3 — REQUIRED for real YouTube comments
# Setup guide: docs/04-YOUTUBE-API-SETUP.md
YOUTUBE_API_KEY=AIzaSyAtw4DPCm_bfTtngjE4IW_wEI22W7S7ZjE

# Not configured (demo data used):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=SentiPulse/1.0
TWITTER_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
